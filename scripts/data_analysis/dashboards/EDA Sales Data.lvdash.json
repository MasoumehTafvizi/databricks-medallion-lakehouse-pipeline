{
  "datasets": [
    {
      "name": "2c6b2328",
      "displayName": "Sales Summary Insights and Performance Metrics",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT\n",
        "    ROUND(SUM(s.sales_amount), 2) AS total_sales,\n",
        "    ROUND(\n",
        "        SUM(s.sales_amount - (s.quantity * p.cost)),\n",
        "        2\n",
        "    ) AS total_profit,\n",
        "    SUM(s.quantity) AS total_quantity\n",
        "FROM workspace.salesdb.fact_sales AS s\n",
        "LEFT JOIN workspace.salesdb.dim_products AS p\n",
        "    ON s.product_key = p.product_key;"
      ]
    },
    {
      "name": "411a3414",
      "displayName": "Aggregate Sales by Product Group Analysis",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `bronze`;\n",
        "\n",
        "SELECT \n",
        "    SUM(sales_amount)AS Sales,\n",
        "    p.category AS category\n",
        "FROM workspace.salesdb.fact_sales s\n",
        "LEFT JOIN workspace.salesdb.dim_products p\n",
        "ON s.product_key = p.product_key\n",
        "GROUP BY p.category\n",
        "ORDER BY p.category"
      ]
    },
    {
      "name": "e08d2c70",
      "displayName": "Monthly Sales Summary Report",
      "queryLines": [
        "USE CATALOG `workspace`;\n",
        "USE SCHEMA `default`;\n",
        "\n",
        "SELECT SUM(sales_amount) AS sales, \n",
        "    DATE_TRUNC('MONTH' ,order_date) month_sales\n",
        "FROM workspace.salesdb.fact_sales\n",
        "GROUP BY DATE_TRUNC('MONTH' ,order_date)\n",
        "ORDER BY month_sales"
      ]
    }
  ],
